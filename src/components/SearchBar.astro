<form class="ui-search" action="/search" method="get">
  <label class="sr-only" for="q">搜索文章</label>
  <span class="ui-search-icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none">
      <path d="m21 21-4.3-4.3m1.3-5.2a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
    </svg>
  </span>
  <input
    id="q"
    name="q"
    class="ui-search-input"
    placeholder="输入标题、标签或关键词..."
    type="search"
  />
  <button class="ui-search-button" type="submit">
    搜索
  </button>
</form>
