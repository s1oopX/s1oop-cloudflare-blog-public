---
import '../styles/global.css';
import '../styles/layout.css';
import '../styles/ui.css';
import '../styles/posts.css';
import '../styles/taxonomy-search.css';
import '../styles/responsive.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  hideChrome?: boolean;
  mainClass?: string;
}

const {
  title = 's1oop的博客',
  description = 's1oop的博客收集设计、写作、阅读与日常思考，适合安静阅读和长期回看。',
  hideChrome = false,
  mainClass,
} = Astro.props;

const mainClasses = mainClass ?? 'site-main flex-1';
const siteTitle = 's1oop的博客';
const documentTitle = title === 's1oop'
  ? siteTitle
  : title
      .replaceAll("s1oop's Blog", siteTitle)
      .replaceAll('s1oop Cloudflare Blog', siteTitle)
      .replaceAll('Cloudflare Blog', 'Blog');
---

<!doctype html>
<html lang="zh-CN" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600;6..72,700&family=Noto+Serif+SC:wght@400;500;600;700&display=optional"
    />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png?v=7" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png?v=7" />
    <link rel="icon" type="image/png" sizes="256x256" href="/favicon.png?v=7" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=7" />
    <title>{documentTitle}</title>
  </head>
  <body class="site-body flex min-h-screen flex-col">
    {!hideChrome && <a href="#main-content" class="skip-link">跳到主要内容</a>}
    {!hideChrome && <Header />}
    <main id="main-content" class={mainClasses}>
      <slot />
    </main>
    {!hideChrome && <Footer />}
    <script type="module" src="/scripts/panel-pointer.js"></script>
  </body>
</html>
