---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  hideChrome?: boolean;
  mainClass?: string;
}

const {
  title = 's1oop的博客',
  description = 's1oop的博客收集设计、写作、阅读与日常思考，适合安静阅读和长期回看。',
  hideChrome = false,
  mainClass,
} = Astro.props;

const mainClasses = mainClass ?? 'site-main flex-1';
const siteTitle = 's1oop的博客';
const documentTitle = title === 's1oop'
  ? siteTitle
  : title
      .replaceAll("s1oop's Blog", siteTitle)
      .replaceAll('s1oop Cloudflare Blog', siteTitle)
      .replaceAll('Cloudflare Blog', 'Blog');
---

<!doctype html>
<html lang="zh-CN" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png?v=7" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png?v=7" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png?v=7" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=7" />
    <title>{documentTitle}</title>
  </head>
  <body class="site-body flex min-h-screen flex-col">
    {!hideChrome && <Header />}
    <main class={mainClasses}>
      <slot />
    </main>
    {!hideChrome && <Footer />}
    <script is:inline>
      document.addEventListener('pointermove', (event) => {
        const panel = event.target.closest?.('.ui-panel');
        if (!panel) return;

        const rect = panel.getBoundingClientRect();
        panel.style.setProperty('--pointer-x', `${event.clientX - rect.left}px`);
        panel.style.setProperty('--pointer-y', `${event.clientY - rect.top}px`);
      });
    </script>
  </body>
</html>
