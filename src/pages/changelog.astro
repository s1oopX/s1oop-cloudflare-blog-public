---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import '../styles/changelog.css';

const records = [
  {
    date: '2026/05/03',
    label: 'landing detail',
    title: '首页滚动提示回到中轴。',
    summary: '入口页底部的胶囊提示保持原来的呼吸节奏，但内部光点不再贴向左侧。这个调整很小，只处理视觉重心，让头像、标题和下滑提示落在同一条垂直线上。',
    scope: '首页入口 / 滚动提示 / 视觉对齐',
    impact: '第一屏的中心线更稳定，细节不会在静态截图里显得偏移。',
    notes: [
      '滚动提示光点水平居中',
      '保留原有上下浮动动画',
      '不影响分页圆点和入口交互',
    ],
  },
  {
    date: '2026/05/03',
    label: 'comment workflow',
    title: '评论系统接入 D1，并加入同网限制。',
    summary: '评论不再只是页面占位。前台可以读取、提交和展示留言，后台可以查看与删除评论；同一网络最多保留 2 条评论，超过时给出明确的中文提示。',
    scope: '文章页 / D1 / 评论 API / 后台管理',
    impact: '留言能力从静态展示变成可运营流程，同时避免单个来源反复刷屏。',
    notes: [
      '新增 blog_comments 数据表',
      '评论开关控制读取和提交',
      '超过限制返回“同一网络最多留言 2 条”',
    ],
  },
  {
    date: '2026/05/03',
    label: 'private admin',
    title: '个人后台的安全边界被收紧。',
    summary: '后台入口、密码校验和运行时脚本加载被重新梳理。管理功能仍然保持轻量，但不会把未授权访问、脚本加载顺序和接口错误混在一起。',
    scope: '个人后台 / 管理 API / 脚本加载',
    impact: '管理页的失败状态更清楚，发布和设置操作不容易被前端脚本状态拖偏。',
    notes: [
      '强化私有入口校验',
      '修复后台脚本打包和加载顺序',
      '管理模块拆分为更明确的运行时职责',
    ],
  },
  {
    date: '2026/05/02',
    label: 'runtime publishing',
    title: '运行时发布链路更轻。',
    summary: '文章、图片和后台工具被拆成更小的运行时模块。静态构建继续负责公开页面，D1 和 Worker 负责需要即时变更的内容。',
    scope: '发布工具 / Worker API / 文章运行时',
    impact: '后台发布不用等待整站重新整理，本地开发和线上接口也更容易分别定位问题。',
    notes: [
      '优化文章运行时读取',
      '拆分后台管理脚本',
      '降低图片和样式资源负担',
    ],
  },
  {
    date: '2026/05/02',
    label: 'reading contrast',
    title: '暗色阅读的对比度被重新校准。',
    summary: '围绕暗色阅读页补充了文字、线条和留白的判断。页面不再只追求“看得清”，而是把标题、正文、边框和辅助信息放回同一套阅读层级里。',
    scope: '文章页 / 列表卡片 / 暗色视觉',
    impact: '长时间阅读时，正文更稳定，界面装饰不会反复抢走注意力。',
    notes: [
      '补充暗色对比度文章',
      '统一标题和正文的明度层级',
      '降低边框与图片对正文的干扰',
    ],
  },
  {
    date: '2026/05/02',
    label: 'archive signal',
    title: '站点状态改成克制的绿色呼吸灯。',
    summary: '侧栏状态不再模拟复杂检测流程，只保留一个固定尺寸的绿色光源。它以深浅变化暗示站点仍在运行，同时不打断档案页的阅读节奏。',
    scope: '全部档案 / 侧栏状态',
    impact: '状态提示更像环境信号，而不是突兀的功能卡片。',
    notes: [
      '固定光点尺寸',
      '只动画透明度',
      '绿色渐变与暗色底版保持一致',
    ],
  },
  {
    date: '2026/04/30',
    label: 'reading order',
    title: '入口被重新收束。',
    summary: '全部档案、专栏、搜索和关于被固定为主要入口。读者不需要理解站内结构，只需要选择档案、专栏或关键词。',
    scope: '顶部导航 / 全部档案 / 专栏 / 搜索',
    impact: '访问路径从“找页面”变成“选阅读方式”。',
    notes: [
      '全部文章保留完整脉络',
      '专栏承担连续阅读路线',
      '搜索合并相近主题入口',
    ],
  },
  {
    date: '2026/04/30',
    label: 'reading surface',
    title: '文章页开始服务长时间停留。',
    summary: '目录、文章信息和继续阅读被放回阅读场景里。页面不追求热闹，而是让一篇文章能被安静读完，也能继续接到下一篇。',
    scope: '文章详情 / 目录 / 继续阅读',
    impact: '读者可以先判断篇幅，再决定跳读、通读或继续读相近主题。',
    notes: [
      '长文目录辅助跳转',
      '日期、字数和阅读时间保留判断依据',
      '相近主题优先进入继续阅读',
    ],
  },
  {
    date: '2026/04/30',
    label: 'visual system',
    title: '视觉回到暗色档案气质。',
    summary: '头像、图片、卡片和阅读页保持同一种克制感。图片负责给出内容线索，不抢走文章本身的位置。',
    scope: '首页 / 文章卡片 / 阅读页',
    impact: '站点开始形成稳定的个人档案识别，而不是一组分散模板。',
    notes: [
      '列表使用图文并置',
      '图片统一降低饱和和亮度',
      '暗色底版保持连续',
    ],
  },
  {
    date: '2026/04/29',
    label: 'first layer',
    title: '博客从可访问开始。',
    summary: '第一批入口只解决一件事：让文章被找到、被读到、被重新打开。这里先确定博客的内容方向，再让之后的整理围绕这个基础继续收紧。',
    scope: '首页 / 第一篇文章 / 基础入口',
    impact: '读者能先理解这里会写什么，再进入具体文章。',
    notes: [
      '全部档案可直接进入',
      '内容方向被写入第一篇说明',
      '搜索用于回找具体片段',
    ],
  },
  {
    date: '2026/04/28',
    label: 'content order',
    title: '文章整理方式被固定下来。',
    summary: '围绕标题、摘要、主题和专栏建立更稳定的整理方式。文章可以保持个人表达，但进入公开阅读前需要有可回看的结构。',
    scope: '文章元信息 / 专栏 / 搜索索引',
    impact: '后续文章可以自然进入同一套列表、主题和搜索系统。',
    notes: [
      '标题和摘要承担判断入口',
      '主题标签减少分散',
      '专栏用于组织连续阅读路线',
    ],
  },
  {
    date: '2026/04/27',
    label: 'publishing checklist',
    title: '公开文章有了发布前检查清单。',
    summary: '在内容进入博客之前，先检查标题是否具体、摘要是否有效、主题是否准确、正文是否有层级。它让个人记录更适合被之后重新阅读。',
    scope: '写作流程 / 发布前检查',
    impact: '减少临时碎片进入公开页面，让档案保持长期可读。',
    notes: [
      '检查标题、摘要和主题',
      '控制段落长度和层级',
      '保留结尾收束',
    ],
  },
];

const latestRecord = records[0];
const releaseStats = [
  { label: 'latest', value: latestRecord.date },
  { label: 'records', value: String(records.length).padStart(2, '0') },
  { label: 'focus', value: 'reading / admin / runtime' },
];
---

<BaseLayout title="更新记录 | s1oop's Blog">
  <section class="ui-page archive-page changelog-page">
    <PageHeader
      eyebrow="site updates"
      title="更新记录"
      description="只保留会改变阅读入口、内容秩序、后台流程和视觉判断的节点。"
    />

    <div class="changelog-shell ui-page-body">
      <section class="changelog-overview ui-panel" aria-label="更新记录概览">
        <div>
          <p class="ui-eyebrow">current state</p>
          <h2>{latestRecord.title}</h2>
          <p>{latestRecord.impact}</p>
        </div>
        <dl>
          {releaseStats.map((item) => (
            <div>
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))}
        </dl>
      </section>

      <div class="changelog-list ui-stagger">
        {records.map((record, index) => (
          <article class="changelog-entry ui-panel">
            <span class="changelog-branch" aria-hidden="true"></span>
            <div class="changelog-entry-index">
              <span>{String(records.length - index).padStart(2, '0')}</span>
              <time>{record.date}</time>
            </div>
            <div class="changelog-entry-main">
              <p class="ui-eyebrow">{record.label}</p>
              <h2>{record.title}</h2>
              <p>{record.summary}</p>
              <div class="changelog-entry-context">
                <span>{record.scope}</span>
                <span>{record.impact}</span>
              </div>
              <ul>
                {record.notes.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
              {record.link && (
                <a class="changelog-entry-link" href={record.link.href}>
                  {record.link.label}
                  <span aria-hidden="true">-&gt;</span>
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
