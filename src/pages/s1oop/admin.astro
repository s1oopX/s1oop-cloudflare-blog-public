---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
---

<BaseLayout
  title="个人管理 | s1oop's Blog"
  description="s1oop 的个人管理页面"
>
  <section class="ui-page archive-page private-page" aria-label="s1oop 个人管理">
    <PageHeader
      eyebrow="PRIVATE CONSOLE"
      title="个人控制台"
      description="Markdown 发布、评论、接口状态和后续功能都放在这里管理。"
    >
      <a slot="actions" class="private-admin-secondary" href="/blog">回到博客</a>
      <button slot="actions" id="private-lock-button" class="private-admin-secondary" type="button">锁定</button>
    </PageHeader>

    <div class="private-dashboard ui-page-body" data-auth="checking">
    <div class="private-dashboard-status" aria-label="管理状态">
      <div class="private-status-card">
        <span>访问状态</span>
        <strong id="admin-auth-state">验证中</strong>
      </div>
      <div class="private-status-card">
        <span>文章发布</span>
        <strong id="admin-workflow-state">待提交</strong>
      </div>
      <div class="private-status-card">
        <span>评论</span>
        <strong>预留</strong>
      </div>
      <div class="private-status-card">
        <span>接口</span>
        <strong>已接入</strong>
      </div>
    </div>

    <div class="private-dashboard-grid">
      <main class="private-dashboard-main">
        <section class="private-dashboard-panel private-publish-panel" aria-labelledby="publish-title">
          <div class="private-panel-head">
            <div>
              <p class="private-admin-kicker">publish</p>
              <h2 id="publish-title">发布文章</h2>
            </div>
            <span id="admin-file-state" class="private-panel-badge">未选择</span>
          </div>

          <form id="post-upload" class="private-admin-form private-admin-upload" novalidate>
            <label class="private-admin-file">
              <span id="post-file-label">选择 Markdown 文件</span>
              <input id="post-file" name="file" type="file" accept=".md,.mdx,text/markdown" required />
            </label>
            <input
              id="post-slug"
              class="private-admin-input"
              name="slug"
              type="text"
              placeholder="文件名，可留空"
            />
            <div class="private-file-summary" aria-label="文件摘要">
              <div>
                <span>标题</span>
                <strong id="post-meta-title">等待文件</strong>
              </div>
              <div>
                <span>日期</span>
                <strong id="post-meta-date">-</strong>
              </div>
              <div>
                <span>大小</span>
                <strong id="post-meta-size">-</strong>
              </div>
            </div>
            <div class="private-admin-actions">
              <button class="private-admin-button" type="submit">提交发布</button>
              <button id="post-clear-button" class="private-admin-secondary" type="button">清空</button>
            </div>
          </form>

          <p id="post-upload-state" class="private-admin-state private-admin-state-inline">支持 .md / .mdx</p>
        </section>

        <section class="private-dashboard-panel" aria-labelledby="modules-title">
          <div class="private-panel-head">
            <div>
              <p class="private-admin-kicker">modules</p>
              <h2 id="modules-title">功能管理</h2>
            </div>
          </div>
          <div class="private-feature-list">
            <div>
              <span>内容</span>
              <strong>Markdown 发布</strong>
              <p>使用当前文章模板检查 frontmatter、摘要、标签和配图。</p>
            </div>
            <div>
              <span>评论</span>
              <strong>暂未开放</strong>
              <p>预留审核、隐藏、删除和来源限制，后续接入评论存储。</p>
            </div>
            <div>
              <span>接口</span>
              <strong>/api/admin/*</strong>
              <p>集中查看发布、鉴权、评论和未来统计接口的接入状态。</p>
            </div>
          </div>
        </section>

        <section class="private-dashboard-panel" aria-labelledby="checklist-title">
          <div class="private-panel-head">
            <div>
              <p class="private-admin-kicker">review</p>
              <h2 id="checklist-title">内容检查</h2>
            </div>
          </div>
          <ul class="private-checklist">
            <li><span>Frontmatter</span><strong>title / date</strong></li>
            <li><span>摘要</span><strong>列表可读</strong></li>
            <li><span>标签</span><strong>沿用既有主题</strong></li>
            <li><span>配图</span><strong>public/images</strong></li>
          </ul>
        </section>
      </main>

      <aside class="private-dashboard-side" aria-label="辅助信息">
        <section class="private-dashboard-panel">
          <div class="private-panel-head">
            <div>
              <p class="private-admin-kicker">api</p>
              <h2>接口状态</h2>
            </div>
          </div>
          <div class="private-operation-list">
            <div>
              <span>鉴权</span>
              <strong>/api/admin/check</strong>
            </div>
            <div>
              <span>发布</span>
              <strong>/api/admin/posts</strong>
            </div>
            <div>
              <span>评论</span>
              <strong>待接入</strong>
            </div>
            <div>
              <span>公开接口</span>
              <strong>只读优先</strong>
            </div>
          </div>
        </section>

        <section class="private-dashboard-panel">
          <div class="private-panel-head">
            <div>
              <p class="private-admin-kicker">session</p>
              <h2>会话</h2>
            </div>
          </div>
          <div class="private-operation-list">
            <div>
              <span>当前会话</span>
              <strong>浏览器本地保存</strong>
            </div>
            <div>
              <span>锁定后</span>
              <strong>清除访问凭据</strong>
            </div>
            <div>
              <span>发布后</span>
              <strong>等待构建刷新</strong>
            </div>
          </div>
        </section>
      </aside>
    </div>
    </div>
  </section>

  <script is:inline>
    const passwordKey = 's1oop-admin-password';
    const uploadForm = document.querySelector('#post-upload');
    const uploadState = document.querySelector('#post-upload-state');
    const lockButton = document.querySelector('#private-lock-button');
    const clearButton = document.querySelector('#post-clear-button');
    const fileInput = document.querySelector('#post-file');
    const fileLabel = document.querySelector('#post-file-label');
    const authState = document.querySelector('#admin-auth-state');
    const dashboard = document.querySelector('.private-dashboard');
    const fileState = document.querySelector('#admin-file-state');
    const workflowState = document.querySelector('#admin-workflow-state');
    const metaTitle = document.querySelector('#post-meta-title');
    const metaDate = document.querySelector('#post-meta-date');
    const metaSize = document.querySelector('#post-meta-size');

    const formatError = (message) => {
      if (message === 'Invalid password') return '密码不正确';
      if (message === 'ADMIN_PASSWORD is not configured') return '访问密码未配置';
      if (message?.includes('GitHub publishing is not configured')) return 'GitHub 发布未配置';
      return message || '操作失败';
    };

    const setState = (node, text, tone = 'muted') => {
      if (!node) return;
      node.textContent = text;
      node.dataset.tone = tone;
    };

    const setFileMeta = ({ title = '等待文件', date = '-', size = '-' } = {}) => {
      if (metaTitle) metaTitle.textContent = title;
      if (metaDate) metaDate.textContent = date;
      if (metaSize) metaSize.textContent = size;
    };

    const parseFrontmatterValue = (source, key) => {
      const match = source.match(/^---\s*\n([\s\S]+?)\n---/);
      if (!match) return null;
      const field = match[1].match(new RegExp(`^${key}:\\s*['\"]?(.+?)['\"]?\\s*$`, 'm'));
      return field?.[1]?.trim() || null;
    };

    const readableSize = (size) => {
      if (size < 1024) return `${size} B`;
      return `${Math.round(size / 1024)} KB`;
    };

    const verifyPassword = async (password) => {
      const response = await fetch('/api/admin/check', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ password }),
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok || !data.ok) throw new Error(data.message || '密码验证失败');
      return data;
    };

    const getPassword = () => sessionStorage.getItem(passwordKey);

    const lockAndExit = () => {
      sessionStorage.removeItem(passwordKey);
      window.location.replace('/s1oop');
    };

    const existingPassword = getPassword();
    if (!existingPassword) {
      window.location.replace('/s1oop');
    } else {
      verifyPassword(existingPassword)
        .then(() => {
          if (dashboard) dashboard.dataset.auth = 'unlocked';
          setState(authState, '已解锁', 'success');
        })
        .catch(() => {
          lockAndExit();
        });
    }

    fileInput?.addEventListener('change', () => {
      const file = fileInput.files?.[0];
      if (!file) {
        if (fileLabel) fileLabel.textContent = '选择 Markdown 文件';
        setState(fileState, '未选择');
        setFileMeta();
        return;
      }
      if (fileLabel) fileLabel.textContent = file.name;
      setState(fileState, '已选择', 'success');
      setState(workflowState, '待提交');
      setFileMeta({ title: '读取中', date: '-', size: readableSize(file.size) });
      file.text()
        .then((markdown) => {
          setFileMeta({
            title: parseFrontmatterValue(markdown, 'title') || '缺少 title',
            date: parseFrontmatterValue(markdown, 'date') || '缺少 date',
            size: readableSize(file.size),
          });
        })
        .catch(() => {
          setFileMeta({ title: '无法读取', date: '-', size: readableSize(file.size) });
        });
    });

    clearButton?.addEventListener('click', () => {
      uploadForm?.reset();
      if (fileLabel) fileLabel.textContent = '选择 Markdown 文件';
      setState(fileState, '未选择');
      setState(workflowState, '待提交');
      setFileMeta();
      setState(uploadState, '支持 .md / .mdx', 'muted');
    });

    uploadForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const password = getPassword();
      if (!password) {
        lockAndExit();
        return;
      }

      const form = new FormData(uploadForm);
      const file = form.get('file');
      if (!file || !file.name) {
        setState(uploadState, '请选择 .md 或 .mdx 文件', 'error');
        setState(workflowState, '缺少文件', 'error');
        return;
      }

      setState(uploadState, '正在提交...', 'muted');
      setState(workflowState, '提交中');
      try {
        const response = await fetch('/api/admin/posts', {
          method: 'POST',
          headers: { authorization: `Bearer ${password}` },
          body: form,
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || !data.ok) throw new Error(data.message || '发布失败');
        setState(uploadState, `已提交：${data.path}`, 'success');
        setState(workflowState, '已提交', 'success');
        uploadForm.reset();
        if (fileLabel) fileLabel.textContent = '选择 Markdown 文件';
        setState(fileState, '未选择');
        setFileMeta();
      } catch (error) {
        setState(uploadState, formatError(error.message), 'error');
        setState(workflowState, '失败', 'error');
      }
    });

    lockButton?.addEventListener('click', () => {
      lockAndExit();
    });
  </script>
</BaseLayout>
