---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import '../../styles/private-access.css';
import '../../styles/private-dashboard.css';
import '../../styles/private-management.css';
---

<BaseLayout
  title="个人管理 | s1oop's Blog"
  description="s1oop 的个人管理页面"
>
  <section class="ui-page archive-page private-page" aria-label="s1oop 个人管理">
    <PageHeader
      eyebrow="PRIVATE CONSOLE"
      title="个人控制台"
      description="Markdown 和小图都写入 D1，发布后不再回写 GitHub。"
    >
      <a slot="actions" class="private-admin-secondary" href="/blog">回到博客</a>
      <button slot="actions" id="private-lock-button" class="private-admin-secondary" type="button">锁定</button>
    </PageHeader>

    <div class="private-dashboard ui-page-body" data-auth="checking">
      <div class="private-dashboard-status" aria-label="管理状态">
        <div class="private-status-card">
          <span>访问状态</span>
          <strong id="admin-auth-state">验证中</strong>
        </div>
        <div class="private-status-card">
          <span>实时发布</span>
          <strong id="admin-workflow-state">待提交</strong>
        </div>
        <div class="private-status-card">
          <span>评论</span>
          <strong id="admin-comment-state">读取中</strong>
        </div>
        <div class="private-status-card">
          <span>D1 文章</span>
          <strong id="admin-post-count">-</strong>
        </div>
      </div>

      <div class="private-dashboard-grid">
        <main class="private-dashboard-main">
          <section class="private-dashboard-panel private-publish-panel" aria-labelledby="publish-title">
            <div class="private-panel-head">
              <div>
                <p class="private-admin-kicker">publish</p>
                <h2 id="publish-title">实时发布</h2>
              </div>
              <span id="admin-file-state" class="private-panel-badge">未选择</span>
            </div>

            <form id="post-upload" class="private-admin-form private-admin-upload" novalidate>
              <div class="private-template-box" aria-label="模板发布">
                <div class="private-template-head">
                  <div>
                    <p class="private-admin-kicker">template</p>
                    <h3>模板发布</h3>
                  </div>
                  <button id="template-build-button" class="private-admin-secondary private-inline-action" type="button">生成 Markdown</button>
                </div>

                <div class="private-template-grid">
                  <label>
                    <span>标题</span>
                    <input id="template-title" class="private-admin-input" type="text" autocomplete="off" placeholder="例如：安静阅读的整理方式" />
                  </label>
                  <label>
                    <span>发布日期</span>
                    <input id="template-date" class="private-admin-input" type="date" />
                  </label>
                  <label>
                    <span>所属专栏</span>
                    <select id="template-collection" class="private-admin-input">
                      <option value="">不归入专栏</option>
                      <option value="hot">热点分享</option>
                      <option value="tech">方法记录</option>
                      <option value="learn">学习分享</option>
                    </select>
                  </label>
                  <label>
                    <span>补充标签</span>
                    <input id="template-tags" class="private-admin-input" type="text" autocomplete="off" placeholder="写作, 博客，最多补到 4 个" />
                  </label>
                </div>

                <label class="private-template-wide">
                  <span>摘要</span>
                  <textarea id="template-excerpt" class="private-admin-input" rows="2" maxlength="90" placeholder="一句话说明文章主题，适合显示在文章列表。"></textarea>
                </label>

                <label class="private-template-wide">
                  <span>封面 alt</span>
                  <input id="template-image-alt" class="private-admin-input" type="text" autocomplete="off" placeholder="选择配图后会插入为正文第一张图" />
                </label>

                <label class="private-template-wide">
                  <span>正文</span>
                  <textarea id="template-body" class="private-admin-input private-template-body" rows="14" placeholder="开头说明这篇文章解决什么问题。\n\n## 第一节\n\n写具体判断。\n\n## 保持克制\n\n收束到一个可以长期回看的结论。"></textarea>
                </label>

                <p id="template-state" class="private-admin-state private-admin-state-inline" aria-live="polite">填写模板后可直接生成规范 Markdown；也可以继续使用下方高级上传。</p>
              </div>

              <label class="private-admin-file">
                <span id="post-file-label">选择 Markdown 文件</span>
                <input id="post-file" name="file" type="file" accept=".md,.mdx,text/markdown" />
              </label>
              <label class="private-admin-file">
                <span id="post-image-label">选择配图，可多选</span>
                <input id="post-images" name="images" type="file" accept="image/jpeg,image/png,image/webp,image/gif" multiple />
              </label>
              <input
                id="post-slug"
                class="private-admin-input"
                name="slug"
                type="text"
                placeholder="slug，可留空使用文件名"
              />

              <div class="private-file-summary" aria-label="文件摘要">
                <div>
                  <span>标题</span>
                  <strong id="post-meta-title">等待文件</strong>
                </div>
                <div>
                  <span>日期</span>
                  <strong id="post-meta-date">-</strong>
                </div>
                <div>
                  <span>大小</span>
                  <strong id="post-meta-size">-</strong>
                </div>
              </div>

              <div class="private-upload-preview" aria-label="发布前预览">
                <div class="private-preview-row">
                  <span>Slug</span>
                  <strong id="preview-slug">-</strong>
                </div>
                <div class="private-preview-row">
                  <span>摘要</span>
                  <strong id="preview-excerpt">-</strong>
                </div>
                <div class="private-preview-row">
                  <span>标签</span>
                  <strong id="preview-tags">-</strong>
                </div>
                <div class="private-preview-row">
                  <span>封面</span>
                  <strong id="preview-image">-</strong>
                </div>
                <div class="private-preview-row">
                  <span>覆盖</span>
                  <strong id="preview-overwrite">等待检查</strong>
                </div>
              </div>

              <p id="post-image-warning" class="private-admin-state-inline private-admin-state">图片会在前端先检查格式和 1 MB 限制</p>

              <div class="private-admin-actions">
                <button class="private-admin-button" type="submit">写入发布</button>
                <button id="post-clear-button" class="private-admin-secondary" type="button">清空</button>
              </div>
            </form>

            <p id="post-upload-state" class="private-admin-state private-admin-state-inline">支持 .md / .mdx，单张图片不超过 1 MB</p>
            <div id="post-publish-result" class="private-publish-result" hidden>
              <a id="post-open-link" class="private-admin-secondary" href="/blog" target="_blank" rel="noreferrer">打开文章</a>
            </div>
          </section>

          <section class="private-dashboard-panel" aria-labelledby="runtime-posts-title">
            <div class="private-panel-head">
              <div>
                <p class="private-admin-kicker">runtime posts</p>
                <h2 id="runtime-posts-title">D1 文章</h2>
              </div>
              <button id="runtime-posts-refresh" class="private-admin-secondary private-panel-action" type="button">刷新</button>
            </div>
            <div id="runtime-post-list" class="private-post-list" aria-live="polite">
              <p class="private-list-empty">等待读取 D1 文章库</p>
            </div>
          </section>

          <section class="private-dashboard-panel" aria-labelledby="runtime-comments-title">
            <div class="private-panel-head">
              <div>
                <p class="private-admin-kicker">comments</p>
                <h2 id="runtime-comments-title">留言管理</h2>
              </div>
              <span id="runtime-comments-count" class="private-panel-badge">-</span>
              <button id="runtime-comments-refresh" class="private-admin-secondary private-panel-action" type="button">刷新</button>
            </div>
            <div id="runtime-comments-list" class="private-post-list" aria-live="polite">
              <p class="private-list-empty">等待读取留言</p>
            </div>
          </section>

          <section class="private-dashboard-panel" aria-labelledby="checklist-title">
            <div class="private-panel-head">
              <div>
                <p class="private-admin-kicker">review</p>
                <h2 id="checklist-title">内容检查</h2>
              </div>
            </div>
            <ul class="private-checklist">
              <li><span>Frontmatter</span><strong>title / date / excerpt</strong></li>
              <li><span>Slug</span><strong>新增或覆盖会提示</strong></li>
              <li><span>标签</span><strong>上传前预览</strong></li>
              <li><span>配图</span><strong>格式和大小先检查</strong></li>
            </ul>
          </section>
        </main>

        <aside class="private-dashboard-side" aria-label="辅助信息">
          <section class="private-dashboard-panel">
            <div class="private-panel-head">
              <div>
                <p class="private-admin-kicker">comments</p>
                <h2>评论区</h2>
              </div>
            </div>
            <div class="private-toggle-panel">
              <label class="private-toggle">
                <input id="comments-toggle" type="checkbox" />
                <span aria-hidden="true"></span>
                <strong>开放评论区</strong>
              </label>
              <p id="comments-toggle-state" class="private-panel-note">读取评论开关状态</p>
              <p class="private-panel-note">同一 IP 最多提交 2 条留言。</p>
            </div>
          </section>

          <section class="private-dashboard-panel">
            <div class="private-panel-head">
              <div>
                <p class="private-admin-kicker">api</p>
                <h2>接口状态</h2>
              </div>
            </div>
            <div class="private-operation-list">
              <div>
                <span>鉴权</span>
                <strong>/api/admin/check</strong>
              </div>
              <div>
                <span>发布</span>
                <strong>/api/admin/posts</strong>
              </div>
              <div>
                <span>设置</span>
                <strong>/api/admin/settings</strong>
              </div>
              <div>
                <span>公开文章</span>
                <strong>/api/posts</strong>
              </div>
              <div>
                <span>孤儿图片</span>
                <button id="orphan-assets-clean" class="private-admin-secondary private-inline-action" type="button">检查并清理</button>
              </div>
            </div>
          </section>

          <section class="private-dashboard-panel">
            <div class="private-panel-head">
              <div>
                <p class="private-admin-kicker">session</p>
                <h2>会话</h2>
              </div>
            </div>
            <div class="private-operation-list">
              <div>
                <span>当前会话</span>
                <strong>浏览器本地保存</strong>
              </div>
              <div>
                <span>锁定后</span>
                <strong>清除访问凭据</strong>
              </div>
              <div>
                <span>发布后</span>
                <strong>即时显示</strong>
              </div>
            </div>
          </section>
        </aside>
      </div>
    </div>
  </section>

  <script>
    import '../../scripts/private-admin.js';
  </script>
</BaseLayout>
