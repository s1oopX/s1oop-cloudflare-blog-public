---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Pagination from '../../components/Pagination.astro';
import PostCard from '../../components/PostCard.astro';
import SiteStatusPanel from '../../components/SiteStatusPanel.astro';
import { POSTS_PER_PAGE, collectTags, formatPostDate, pageCount, pageItems, postExcerpt, postHref, postImage, visiblePosts } from '../../lib/posts';

const posts = visiblePosts(await getCollection('posts'));
const tags = collectTags(posts);
const latestPost = posts[0];
const currentPage = 1;
const totalPages = pageCount(posts, POSTS_PER_PAGE);
const paginatedPosts = pageItems(posts, currentPage, POSTS_PER_PAGE);
---

<BaseLayout title="全部档案 | s1oop's Blog">
  <section class="ui-page archive-page">
    <PageHeader
      eyebrow="full archive"
      title="全部档案"
      description="所有已经整理好的文章都保留在这里。这里是默认入口，适合慢慢回看。"
    />

    <div class="ui-grid ui-page-body">
      <div class="ui-stack ui-stagger">
        {paginatedPosts.map((post) => (
          <PostCard
            title={post.data.title}
            excerpt={postExcerpt(post)}
            href={postHref(post)}
            date={formatPostDate(post.data.date)}
            tags={post.data.tags}
            image={postImage(post)}
          />
        ))}
        <Pagination currentPage={currentPage} totalPages={totalPages} baseHref="/blog/page" firstHref="/blog" />
      </div>

      <aside class="ui-sidebar ui-stagger">
        <SiteStatusPanel />

        <section class="ui-panel">
          <div class="ui-panel-header">
            <h2 class="text-sm font-medium text-white">阅读概览</h2>
          </div>
          <div class="ui-panel-body grid gap-4">
            <div class="ui-stat-row">
              <span class="ui-stat-label">文章</span>
              <span class="ui-stat-value">{posts.length}</span>
            </div>
            <div class="ui-stat-row">
              <span class="ui-stat-label">标签</span>
              <span class="ui-stat-value">{tags.length}</span>
            </div>
            <div class="ui-stat-row">
              <span class="ui-stat-label">最新</span>
              <span class="ui-stat-value">{latestPost ? formatPostDate(latestPost.data.date) : '-'}</span>
            </div>
          </div>
        </section>
      </aside>
    </div>
  </section>
</BaseLayout>
