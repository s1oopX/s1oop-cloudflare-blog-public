---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArchiveSidebar from '../../components/ArchiveSidebar.astro';
import PageHeader from '../../components/PageHeader.astro';
import Pagination from '../../components/Pagination.astro';
import { collectionHref, collections } from '../../lib/collections';
import { POSTS_PER_PAGE } from '../../lib/posts';

const currentPage = 1;
const totalPages = 1;
const archivePaths = collections.map((collection) => ({
  slug: collection.slug,
  href: collectionHref(collection),
  title: collection.title,
  count: 0,
  runtimeTags: collection.runtimeTags,
}));
const initialPostData: unknown[] = [];
---

<BaseLayout title="全部内容 | s1oop's Blog">
  <section class="ui-page archive-page">
    <PageHeader
      eyebrow="full archive"
      title="全部内容"
      description="所有已经整理好的文章都保留在这里。这里是默认入口，适合慢慢回看。"
    />

    <div class="ui-grid ui-page-body">
      <div
        class="ui-stack ui-stagger archive-post-list"
        data-post-list
        data-page-size={POSTS_PER_PAGE}
        data-initial-posts={JSON.stringify(initialPostData)}
        data-archive-paths={JSON.stringify(archivePaths)}
      >
        <div class="ui-panel p-5 text-sm text-zinc-400" data-archive-empty>正在读取 D1 文章。</div>
        <div data-post-pagination>
          <Pagination currentPage={currentPage} totalPages={totalPages} baseHref="/blog" queryParam="page" />
        </div>
      </div>

      <ArchiveSidebar
        postCount={0}
        tagCount={0}
        latestLabel="-"
      />
    </div>
  </section>

  <script type="module" src="/scripts/blog-index.js"></script>
</BaseLayout>
