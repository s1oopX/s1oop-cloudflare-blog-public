---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Comments from '../../components/Comments.astro';
import '../../styles/reading.css';
import '../../styles/article-sidebar.css';
---

<BaseLayout title="实时文章 | s1oop's Blog">
  <article class="ui-page reading-page" data-live-post-page>
    <PageHeader
      eyebrow="reading"
      title="文章阅读"
      description="正在整理文章内容。"
    >
      <Fragment slot="actions">
        <a href="/blog" class="ui-button">全部内容</a>
      </Fragment>
    </PageHeader>

    <div class="ui-grid ui-page-body">
      <div class="ui-stack">
        <div class="post-content reading-surface ui-panel p-6 sm:p-8" data-live-post-content>
          <p>正在读取文章。</p>
        </div>

        <nav class="reading-nav" aria-label="文章导航" data-live-post-nav hidden></nav>

        <Comments />
      </div>

      <aside class="ui-sidebar reading-sidebar ui-stagger">
        <section class="ui-panel">
          <div class="ui-panel-header">
            <h2 class="ui-panel-title">文章信息</h2>
          </div>
          <div class="ui-panel-body grid gap-4">
            <div class="ui-stat-row">
              <span class="ui-stat-label">日期</span>
              <span class="ui-stat-value" data-live-post-date>-</span>
            </div>
            <div class="ui-stat-row" data-live-post-updated-row hidden>
              <span class="ui-stat-label">最后编辑</span>
              <span class="ui-stat-value" data-live-post-updated>-</span>
            </div>
            <div class="ui-stat-row">
              <span class="ui-stat-label">类型</span>
              <span class="ui-stat-value" data-live-post-type>-</span>
            </div>
            <div class="ui-stat-row">
              <span class="ui-stat-label">字数</span>
              <span class="ui-stat-value" data-live-post-words>-</span>
            </div>
            <div class="ui-stat-row">
              <span class="ui-stat-label">阅读</span>
              <span class="ui-stat-value" data-live-post-minutes>-</span>
            </div>
            <div class="grid gap-2 border-t border-white/10 pt-4">
              <span class="ui-stat-label">标签</span>
              <div class="flex flex-wrap gap-2" data-live-post-tags></div>
            </div>
          </div>
        </section>

        <section class="ui-panel">
          <div class="ui-panel-header">
            <h2 class="ui-panel-title">继续阅读</h2>
          </div>
          <div class="ui-panel-body article-related-list" data-live-related-posts>
            <p class="text-sm text-zinc-400">正在整理相关内容。</p>
          </div>
        </section>
      </aside>
    </div>
  </article>

  <script type="module" src="/scripts/live-post.js"></script>
</BaseLayout>
