---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import '../styles/about.css';

const githubUrl = 'https://github.com/s1oopX';
const gmailAddress = 's1oopp1337@gmail.com';

const contactRows = [
  { label: 'GitHub', value: 's1oopX', href: githubUrl, icon: 'github' },
  { label: 'Gmail', value: gmailAddress, href: `mailto:${gmailAddress}`, icon: 'mail' },
];

const profileRows = [
  { label: 'Owner', value: 's1oop' },
  { label: 'Type', value: 'Personal archive' },
  { label: 'Public source', value: 'D1 live posts' },
];

const principles = [
  {
    label: 'Reading',
    title: '优先阅读',
    copy: '正文、目录和入口比装饰更重要。页面应当保持安静，让内容自己留下判断。',
  },
  {
    label: 'Publishing',
    title: '降低维护',
    copy: '公开文章统一进入 D1，代码只负责页面壳、样式和后台工具，避免两套内容源。',
  },
  {
    label: 'Archive',
    title: '方便回找',
    copy: '专栏负责连续主题，搜索负责片段回看，更新记录说明站点变化。',
  },
];

const projectRows = [
  {
    label: 'Shell',
    value: 'Astro',
    copy: '公开页面保持轻量壳层，负责导航、排版和阅读结构。',
  },
  {
    label: 'Repository',
    value: 'GitHub',
    copy: '代码、样式和页面组件集中维护，内容源不再拆成静态与运行时两套。',
  },
  {
    label: 'Runtime',
    value: 'Cloudflare Pages',
    copy: '前台页面和边缘函数部署在同一条发布链路上。',
  },
  {
    label: 'Content',
    value: 'Cloudflare D1',
    copy: '实时文章、小图和运行时元数据统一读取自 D1。',
  },
];
---

<BaseLayout
  title="关于 | s1oop's Blog"
  description="关于 s1oop's Blog：一个面向长期阅读和轻量维护的个人博客。"
>
  <section class="ui-page archive-page about-page">
    <PageHeader
      eyebrow="public profile"
      title="关于"
      description="这里保存写作、阅读、设计判断和轻量技术实践。它是一个长期维护的个人档案入口。"
    >
      <a class="ui-button" href={githubUrl} target="_blank" rel="noreferrer" slot="actions">GitHub</a>
      <a class="ui-button" href={`mailto:${gmailAddress}`} slot="actions">Gmail</a>
    </PageHeader>

    <div class="ui-grid ui-page-body">
      <main class="ui-stack ui-stagger">
        <section class="ui-panel about-record" aria-labelledby="about-record-title">
          <div class="about-record-head">
            <div>
              <p class="ui-eyebrow">s1oop's Blog</p>
              <h2 id="about-record-title">长期回看的个人档案。</h2>
            </div>
            <span>D1 live source</span>
          </div>
          <div class="about-record-body">
            <p>
              这个博客不按热度排序，也不追逐频繁刷新。它把文章、标签、专栏和搜索组织成稳定入口，
              让写过的内容在之后还能被找到、读懂和继续修正。
            </p>
            <div class="about-principle-list" aria-label="站点维护原则">
              {principles.map((item) => (
                <article>
                  <p class="ui-eyebrow">{item.label}</p>
                  <h3>{item.title}</h3>
                  <p>{item.copy}</p>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="ui-panel about-project" aria-labelledby="about-project-title">
          <div class="ui-panel-header">
            <p class="ui-eyebrow">project structure</p>
            <h2 id="about-project-title">项目介绍</h2>
          </div>
          <div class="about-project-body">
            <p>
              这个站点不是完整后台系统，也不是纯静态文章仓库。它更接近一个公开阅读壳：
              页面负责呈现和导航，实时内容交给 Cloudflare 的边缘能力和 D1 数据源。
            </p>
            <div class="about-project-grid" aria-label="项目指纹">
              {projectRows.map((item) => (
                <article>
                  <div>
                    <span>{item.label}</span>
                    <strong>{item.value}</strong>
                  </div>
                  <p>{item.copy}</p>
                </article>
              ))}
            </div>
          </div>
        </section>
      </main>

      <aside class="ui-sidebar ui-stagger" aria-label="博客说明">
        <section class="ui-panel about-profile" aria-label="个人博客">
          <div class="about-profile-head">
            <img src="/images/avatar.jpg" alt="" width="128" height="128" loading="eager" decoding="async" />
            <div>
              <p class="ui-eyebrow">s1oop</p>
              <h2>个人博客</h2>
              <p>写作、阅读和实践记录。</p>
            </div>
          </div>
          <dl class="about-meta-list">
            {profileRows.map((item) => (
              <div>
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))}
          </dl>
        </section>

        <section class="ui-panel">
          <div class="ui-panel-header">
            <h2 class="ui-panel-title">正式联系</h2>
          </div>
          <div class="ui-panel-body about-link-list">
            {contactRows.map((item) => (
              <a href={item.href} target={item.href.startsWith('mailto:') ? undefined : '_blank'} rel={item.href.startsWith('mailto:') ? undefined : 'noreferrer'}>
                <span class="about-link-icon" aria-hidden="true">
                  {item.icon === 'github' ? (
                    <svg viewBox="0 0 24 24" fill="none">
                      <path d="M12 2.6a9.4 9.4 0 0 0-3 18.3c.48.08.65-.2.65-.46v-1.6c-2.65.58-3.2-1.13-3.2-1.13-.43-1.08-1.05-1.37-1.05-1.37-.86-.58.07-.57.07-.57.95.07 1.45.98 1.45.98.84 1.44 2.2 1.02 2.74.78.08-.6.33-1.02.6-1.25-2.12-.24-4.34-1.06-4.34-4.7 0-1.04.37-1.89.98-2.55-.1-.24-.43-1.22.09-2.52 0 0 .8-.26 2.6.97a8.9 8.9 0 0 1 4.74 0c1.8-1.23 2.6-.97 2.6-.97.52 1.3.19 2.28.1 2.52.6.66.97 1.51.97 2.55 0 3.65-2.23 4.46-4.35 4.7.34.3.64.88.64 1.77v2.62c0 .26.17.55.66.46A9.4 9.4 0 0 0 12 2.6Z" />
                    </svg>
                  ) : (
                    <svg viewBox="0 0 24 24" fill="none">
                      <path d="M4.75 6.75h14.5v10.5H4.75V6.75Z" />
                      <path d="m5.25 7.25 6.75 5.5 6.75-5.5" />
                    </svg>
                  )}
                </span>
                <span class="about-link-copy">
                  <span>{item.label}</span>
                  <strong>{item.value}</strong>
                </span>
              </a>
            ))}
          </div>
        </section>
      </aside>
    </div>
  </section>
</BaseLayout>
