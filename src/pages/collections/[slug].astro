---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { collectionBySlug, collections } from '../../lib/collections';
import { POSTS_PER_PAGE } from '../../lib/posts';

export function getStaticPaths() {
  return collections.map((collection) => ({ params: { slug: collection.slug } }));
}

const { slug } = Astro.params;
const collection = collectionBySlug(slug);
if (!collection) throw new Error(`Collection not found: ${slug}`);

const currentPage = 1;
const otherCollections = collections.filter((item) => item.slug !== collection.slug);
const initialPostData: unknown[] = [];
const collectionMeta = {
  slug: collection.slug,
  runtimeTags: collection.runtimeTags,
};
const otherCollectionMeta = otherCollections.map((item) => ({
  slug: item.slug,
  runtimeTags: item.runtimeTags,
  baseCount: 0,
}));
---

<BaseLayout title={`${collection.title} | s1oop's Blog`}>
  <section class="ui-page archive-page">
    <PageHeader
      eyebrow={collection.eyebrow}
      title={collection.title}
      description={collection.description}
    >
      <Fragment slot="actions">
        <a class="ui-button" href="/collections">全部专栏</a>
      </Fragment>
    </PageHeader>

    <div class="ui-grid ui-page-body">
      <div
        class="ui-stack ui-stagger"
        data-collection-post-list
        data-page-size={POSTS_PER_PAGE}
        data-current-page={currentPage}
        data-initial-posts={JSON.stringify(initialPostData)}
        data-collection-meta={JSON.stringify(collectionMeta)}
        data-other-collection-meta={JSON.stringify(otherCollectionMeta)}
      >
        <div class="ui-panel p-5 text-sm text-zinc-400" data-collection-empty>正在读取 D1 文章。</div>
        <div data-collection-pagination></div>
      </div>

      <aside class="ui-sidebar ui-stagger">
        <section class="ui-panel">
          <div class="ui-panel-header">
            <h2 class="ui-panel-title">阅读说明</h2>
          </div>
          <div class="ui-panel-body grid gap-4">
            <p class="text-sm leading-6 text-zinc-400">{collection.description}</p>
            <div class="ui-stat-row">
              <span class="ui-stat-label">文章</span>
              <span class="ui-stat-value" data-collection-total>0</span>
            </div>
            <div class="ui-stat-row">
              <span class="ui-stat-label">最新</span>
              <span class="ui-stat-value" data-collection-latest>-</span>
            </div>
          </div>
        </section>

        <section class="ui-panel">
          <div class="ui-panel-header">
            <h2 class="ui-panel-title">继续选择</h2>
          </div>
          <div class="ui-panel-body sidebar-link-list">
            {otherCollections.map((item) => (
              <a href={`/collections/${item.slug}`} class="sidebar-link-item no-underline">
                <span class="sidebar-link-kicker" data-other-collection-count={item.slug}>0 篇</span>
                <span class="sidebar-link-title">{item.title}</span>
              </a>
            ))}
            {otherCollections.length === 0 && (
              <p class="text-sm text-zinc-400">暂无其他专栏。</p>
            )}
          </div>
        </section>

      </aside>
    </div>
  </section>

  <script type="module" src="/scripts/collection-page.js"></script>
</BaseLayout>
