---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { collectionHref, collections } from '../../lib/collections';

const collectionMeta = collections.map((collection) => ({
  slug: collection.slug,
  runtimeTags: collection.runtimeTags,
}));
---

<BaseLayout title="专栏 | s1oop's Blog">
  <section class="ui-page archive-page">
    <PageHeader
      eyebrow="curated paths"
      title="专栏"
      description="按阅读意图整理的内容路线。你可以从一个主题开始，连续读下去。"
    />

    <div
      class="collection-grid ui-page-body ui-stagger"
      data-collection-grid
      data-collection-meta={JSON.stringify(collectionMeta)}
    >
      {collections.map((collection) => {
        const image = collection.image;
        const titleId = `collection-${collection.slug}-title`;

        return (
          <a href={collectionHref(collection)} class="collection-card ui-panel ui-panel-link no-underline" data-collection-card={collection.slug} aria-labelledby={titleId}>
            {image && (
              <div class="collection-card-image">
                <img src={image.src} alt={image.alt} loading="lazy" decoding="async" />
              </div>
            )}
            <div class="collection-card-body">
              <p class="ui-eyebrow">{collection.eyebrow}</p>
              <div class="mt-3 flex flex-wrap gap-2">
                <span class="ui-badge" data-collection-count>0 篇</span>
              </div>
              <h2 id={titleId}>{collection.title}</h2>
              <p>{collection.description}</p>
              <div class="collection-card-list" data-collection-list></div>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <script type="module" src="/scripts/collections-index.js"></script>
</BaseLayout>
