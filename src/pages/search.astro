---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import SearchBar from '../components/SearchBar.astro';
---

<BaseLayout title="搜索 | s1oop's Blog">
  <section class="ui-page archive-page search-page">
    <PageHeader
      eyebrow="site search"
      title="搜索"
      description="从关键词或主题进入文章。这里同时承担回找和相近内容入口。"
    />

    <div class="ui-grid ui-page-body search-grid">
      <div class="ui-stack ui-stagger">
        <section class="ui-panel" aria-label="站内搜索">
          <div class="ui-panel-body grid gap-4">
            <SearchBar />
            <div class="flex flex-wrap items-center justify-between gap-3 border-t border-white/10 pt-4">
              <p id="search-status" class="search-status">输入关键词后显示结果。</p>
              <span class="font-mono text-[0.68rem] uppercase tracking-[0.12em] text-zinc-500" data-search-summary>正在读取 D1 内容</span>
            </div>
          </div>
        </section>

        <div id="search-results" class="search-results ui-stagger grid gap-5"></div>

        <section class="ui-panel search-topic-panel" aria-labelledby="search-topics-title">
          <div class="ui-panel-header">
            <div>
              <p class="ui-eyebrow">search entry</p>
              <h2 id="search-topics-title" class="mt-2 text-2xl font-semibold text-white">搜索入口</h2>
            </div>
          </div>
          <div class="tag-index-grid search-topic-grid" data-search-topic-grid></div>
        </section>
      </div>

      <aside class="ui-sidebar ui-stagger">
        <section class="ui-panel">
          <div class="ui-panel-header">
            <h2 class="ui-panel-title">搜索概览</h2>
          </div>
          <div class="ui-panel-body grid gap-4">
            <div class="ui-stat-row">
              <span class="ui-stat-label">文章</span>
              <span class="ui-stat-value" data-search-post-count>0</span>
            </div>
            <div class="ui-stat-row">
              <span class="ui-stat-label">入口</span>
              <span class="ui-stat-value" data-search-tag-count>0</span>
            </div>
            <div class="ui-stat-row">
              <span class="ui-stat-label">状态</span>
              <span class="ui-stat-value" id="search-sidebar-state">请输入关键词</span>
            </div>
          </div>
        </section>

        <section class="ui-panel">
          <div class="ui-panel-header">
            <h2 class="ui-panel-title">搜索说明</h2>
          </div>
          <div class="ui-panel-body">
            <p class="text-sm leading-6 text-zinc-400">输入关键词可以回找具体片段，也可以从入口卡片进入相近内容。</p>
          </div>
        </section>
      </aside>
    </div>
  </section>

  <script type="module" src="/scripts/search-page.js"></script>
</BaseLayout>
