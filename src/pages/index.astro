---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/landing-shell.css';
import '../styles/landing-portrait.css';
import '../styles/landing-entry.css';
---

<BaseLayout
  title="s1oop"
  description="进入 s1oop's Blog，阅读设计、写作、内容整理和长期观察。"
  hideChrome={true}
  mainClass="landing-scroll"
>
  <div class="landing-track" data-landing-track>
    <section class="landing-stage landing-stage-profile" aria-label="s1oop profile">
      <div class="landing-fixed">
        <button class="landing-portrait" type="button" aria-label="进入博客入口">
          <img
            class="landing-avatar"
            src="/images/avatar.jpg"
            alt="s1oop avatar"
            width="240"
            height="240"
            loading="eager"
            decoding="async"
          />
          <svg class="landing-border-runner" aria-hidden="true" viewBox="0 0 100 100" preserveAspectRatio="none">
            <rect x="1.5" y="1.5" width="97" height="97" rx="4" pathLength="100" />
          </svg>
        </button>
        <h1 class="landing-title">s1oop's Blog</h1>
      </div>
      <a class="landing-scroll-cue" href="#enter-blog" aria-label="下滑进入博客">
        <span></span>
      </a>
    </section>

    <section id="enter-blog" class="landing-stage landing-stage-entry" aria-label="进入博客">
      <div class="landing-fixed landing-entry">
        <div class="landing-entry-panel">
          <p class="landing-kicker">quiet archive</p>
          <a class="landing-enter" href="/blog">进入博客</a>
          <a class="landing-latest" href="/blog" data-landing-latest hidden>
            <span data-landing-latest-date>最近</span>
            <strong data-landing-latest-title></strong>
            <em data-landing-latest-excerpt></em>
          </a>
        </div>
      </div>
    </section>
  </div>

  <div class="landing-pagination" aria-label="落地页分页">
    <button class="is-active" type="button" data-panel-target="0" aria-label="头像首页" aria-current="true"></button>
    <button type="button" data-panel-target="1" aria-label="进入博客"></button>
  </div>

  <script type="module" src="/scripts/landing.js"></script>
</BaseLayout>
