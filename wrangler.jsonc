{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "s1oop-cloudflare-blog-public-api",
  "main": "workers/api.js",
  "compatibility_date": "2026-05-02",
  "d1_databases": [
    {
      "binding": "BLOG_DB",
      "database_name": "s1oop-blog-content",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ]
}
